---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url><loc>{{ site.url }}/latest/</loc><changefreq>daily</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.url }}/business/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/technology/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/politics/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/culture/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/science/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  {% for post in collections.articles %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | sitemapDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}
</urlset>
