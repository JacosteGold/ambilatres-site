{% extends "layouts/base.njk" %}

{% set extraCss %}
.cat-content { padding: 3rem 0; min-height: 60vh; }
.page-title { font-size: 2.5rem; font-weight: 300; margin-bottom: 0.5rem; letter-spacing: 0.1em; text-transform: uppercase; }
.page-subtitle { color: var(--accent-light); font-size: 1rem; margin-bottom: 3rem; letter-spacing: 0.05em; }
.articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem; }
.article-card { border: 1px solid var(--border); transition: all 0.3s; text-decoration: none; display: block; color: inherit; }
.article-card:hover { border-color: var(--power); transform: translateY(-4px); }
.card-thumb { width: 100%; height: 180px; background: #111; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--border); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); font-weight: 700; }
.card-body { padding: 1.25rem; }
.card-meta { font-size: 0.72rem; color: var(--accent-light); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.5rem; }
.card-title { font-size: 1.2rem; font-weight: 400; line-height: 1.25; margin-bottom: 0.5rem; }
.card-excerpt { font-size: 0.9rem; color: #888; line-height: 1.45; }
.empty { grid-column: 1/-1; text-align: center; padding: 4rem; color: var(--accent-light); }
@media (max-width: 768px) { .articles-grid { grid-template-columns: 1fr; } .page-title { font-size: 1.8rem; } }
{% endset %}

{% block content %}
{% if categorySlug %}{% set articles = collections[categorySlug] %}{% endif %}
<div class="container">
    <section class="cat-content">
        <h1 class="page-title">{{ categoryLabel or title }}</h1>
        <p class="page-subtitle">{{ categoryDesc or description }}</p>

        <div class="articles-grid">
            {% if articles and articles.length %}
                {% for article in articles %}
                <a class="article-card" href="{{ article.url }}">
                    <div class="card-thumb">{{ article.data.category | upper }}</div>
                    <div class="card-body">
                        <div class="card-meta">{{ article.data.category }} · {{ article.date | dateFR }}</div>
                        <h2 class="card-title">{{ article.data.title }}</h2>
                        <p class="card-excerpt">{{ article.data.excerpt | truncate(120) }}</p>
                    </div>
                </a>
                {% endfor %}
            {% else %}
                <div class="empty">Aucun article dans cette catégorie pour l'instant.</div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
