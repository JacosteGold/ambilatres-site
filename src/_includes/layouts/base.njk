<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} — {{ site.title }}</title>
    <meta name="description" content="{{ excerpt or description or site.description }}">

    <!-- SEO Open Graph -->
    <meta property="og:title" content="{{ title }} — {{ site.title }}">
    <meta property="og:description" content="{{ excerpt or description or site.description }}">
    <meta property="og:type" content="{{ 'article' if layout == 'layouts/article.njk' else 'website' }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:site_name" content="{{ site.title }}">
    {% if ogImage %}<meta property="og:image" content="{{ site.url }}/assets/images/{{ ogImage }}">{% endif %}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} — {{ site.title }}">
    <meta name="twitter:description" content="{{ excerpt or description or site.description }}">

    <!-- Article SEO -->
    {% if date %}<meta property="article:published_time" content="{{ date | dateISO }}">{% endif %}
    {% if author %}<meta property="article:author" content="{{ author }}">{% endif %}

    <!-- Canonical -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.url }}/feed.xml">

    <link href="https://fonts.googleapis.com/css2?family=Darker+Grotesque:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/logo3d.ico">

    <style>
        :root {
            --void: #080808;
            --power: #ffffff;
            --accent: #333333;
            --accent-light: #666666;
            --border: rgba(255,255,255,0.1);
            --red: #8b1a1a;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Darker Grotesque', sans-serif; background: var(--void); color: var(--power); min-height: 100vh; overflow-x: hidden; }
        canvas#matrix { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.07; pointer-events: none; filter: blur(0.5px); }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; position: relative; z-index: 1; }
        header { border-bottom: 1px solid var(--accent); background: rgba(8,8,8,0.85); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 100; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 0.8rem; letter-spacing: 0.1em; color: var(--accent-light); }
        .top-bar a { color: var(--accent-light); text-decoration: none; margin-left: 1rem; transition: color 0.3s; }
        .top-bar a:hover { color: var(--power); }
        .main-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 0; }
        .logo { font-size: 2rem; font-weight: 300; letter-spacing: 0.3em; text-decoration: none; color: var(--power); text-transform: uppercase; }
        nav { display: flex; gap: 1.5rem; }
        nav a { color: var(--power); text-decoration: none; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; position: relative; }
        nav a::after { content: ''; position: absolute; bottom: -5px; left: 0; width: 0; height: 1px; background: var(--power); transition: width 0.3s; }
        nav a:hover::after, nav a.active::after { width: 100%; }
        footer { border-top: 1px solid var(--accent); padding: 3rem 0; background: rgba(8,8,8,0.9); margin-top: 4rem; position: relative; z-index: 10; }
        .footer-inner { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem; }
        .footer-links a { color: var(--accent-light); text-decoration: none; margin-right: 1.5rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; transition: color 0.3s; }
        .footer-links a:hover { color: var(--power); }
        .footer-newsletter { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
        .footer-newsletter p { font-size: 0.85rem; color: var(--accent-light); margin-bottom: 0.75rem; letter-spacing: 0.05em; }
        .newsletter-form { display: flex; gap: 0.5rem; max-width: 400px; }
        .newsletter-form input { flex: 1; background: transparent; border: 1px solid var(--accent); color: var(--power); padding: 0.5rem 0.75rem; font-family: inherit; font-size: 0.9rem; outline: none; transition: border-color 0.3s; }
        .newsletter-form input:focus { border-color: var(--power); }
        .newsletter-form button { background: var(--power); color: var(--void); border: none; padding: 0.5rem 1rem; font-family: inherit; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: opacity 0.3s; }
        .newsletter-form button:hover { opacity: 0.85; }
        .coords { font-size: 0.7rem; color: var(--accent); font-family: monospace; }
        @media (max-width: 768px) {
            .main-header { flex-direction: column; gap: 1rem; }
            nav { flex-wrap: wrap; justify-content: center; gap: 1rem; }
            .footer-inner { flex-direction: column; }
        }
        {{ extraCss | safe if extraCss }}
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <canvas id="matrix"></canvas>

    <header>
        <div class="container">
            <div class="top-bar">
                <div id="currentDate"></div>
                <div>
                    <a href="/subscribe/">Subscribe</a>
                    <a href="/feed.xml">RSS</a>
                </div>
            </div>
            <div class="main-header">
                <a href="/" class="logo">AMBILATRES</a>
                <nav>
                    {% for item in site.nav %}
                    <a href="{{ item.url }}"{% if page.url.startsWith(item.url) %} class="active"{% endif %}>{{ item.label }}</a>
                    {% endfor %}
                </nav>
            </div>
        </div>
    </header>

    {% block content %}{% endblock %}

    <footer>
        <div class="container">
            <div class="footer-newsletter">
                <p>NEWSLETTER — Recevoir les prochains articles</p>
                <form class="newsletter-form" action="https://app.brevo.com/PLACEHOLDER" method="post" target="_blank">
                    <input type="email" name="email" placeholder="votre@email.com" required>
                    <button type="submit">S'abonner</button>
                </form>
            </div>
            <div class="footer-inner" style="margin-top:2rem;">
                <div class="footer-links">
                    <a href="mailto:{{ site.email }}">Contact</a>
                    <a href="/about/">About</a>
                    <a href="/privacy/">Privacy</a>
                    <a href="/terms/">Terms</a>
                    <a href="/feed.xml">RSS</a>
                </div>
                <div class="coords">22°17'56"N 114°10'20"E</div>
            </div>
        </div>
    </footer>

    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-analytics-compat.js"></script>
    <script src="/js/firebase-config.js"></script>
    <script>
        document.getElementById('currentDate').textContent = new Date().toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        const canvas = document.getElementById('matrix');
        const ctx = canvas.getContext('2d');
        function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        resizeCanvas();
        const chars = '杜脱脱喜欢小咪咪';
        const fontSize = 14;
        let drops = [];
        function initDrops() { drops = new Array(Math.floor(canvas.width / fontSize)).fill(1); }
        initDrops();
        function draw() {
            ctx.fillStyle = 'rgba(8,8,8,0.05)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#222';
            ctx.font = `${fontSize}px "PingFang SC","Microsoft YaHei",monospace`;
            for (let i = 0; i < drops.length; i++) {
                ctx.fillText(chars[Math.floor(Math.random() * chars.length)], i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > canvas.height && Math.random() > 0.95) drops[i] = 0;
                drops[i]++;
            }
        }
        setInterval(draw, 25);
        window.addEventListener('resize', () => { resizeCanvas(); initDrops(); });
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
