---
title: Global News & Analysis
description: News, analysis and essays on business, finance, technology, politics, culture and science.
---
{% extends "layouts/base.njk" %}

{% set extraCss %}
.hero { border-bottom: 1px solid var(--accent); padding: 3rem 0 2rem; margin-bottom: 2rem; }
.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
.hero-text { padding-right: 2rem; }
.hero-label { font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--red); margin-bottom: 1rem; font-weight: 700; }
.hero-title { font-size: 2.5rem; font-weight: 300; line-height: 1.1; margin-bottom: 1rem; }
.hero-excerpt { color: #aaa; line-height: 1.7; margin-bottom: 1.5rem; }
.hero-link { color: var(--power); text-decoration: none; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; border-bottom: 1px solid var(--power); padding-bottom: 2px; transition: opacity 0.3s; }
.hero-link:hover { opacity: 0.7; }
.hero-img { height: 320px; background: #111; display: flex; align-items: center; justify-content: center; color: var(--accent); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; border: 1px solid var(--border); }
.main-grid { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; padding: 2rem 0 4rem; }
.section-label { font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
.article-card { display: flex; gap: 1.25rem; padding: 1.25rem 0; border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; transition: opacity 0.2s; }
.article-card:hover { opacity: 0.8; }
.card-cat { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); font-weight: 700; margin-bottom: 0.35rem; }
.card-title { font-size: 1.15rem; font-weight: 400; line-height: 1.25; margin-bottom: 0.35rem; }
.card-meta { font-size: 0.75rem; color: var(--accent-light); }
.sidebar-item { padding: 1rem 0; border-bottom: 1px solid var(--border); }
.sidebar-num { font-size: 0.7rem; color: var(--accent-light); letter-spacing: 0.1em; margin-bottom: 0.35rem; }
.sidebar-title { font-size: 0.95rem; font-weight: 400; line-height: 1.3; }
.sidebar-item a { text-decoration: none; color: inherit; transition: color 0.2s; }
.sidebar-item a:hover { color: var(--accent-light); }
@media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-img { display: none; }
    .main-grid { grid-template-columns: 1fr; }
}
{% endset %}

{% block content %}
{% set featured = collections.articles[0] %}
{% set latest = collections.articles | slice(0, 6) %}

<div class="container">

    {% if featured %}
    <section class="hero">
        <div class="hero-inner">
            <div class="hero-text">
                <div class="hero-label">{{ featured.data.badge or featured.data.category }}</div>
                <h1 class="hero-title">{{ featured.data.title }}</h1>
                <p class="hero-excerpt">{{ featured.data.excerpt }}</p>
                <a href="{{ featured.url }}" class="hero-link">Lire l'article →</a>
            </div>
            <div class="hero-img">[ {{ featured.data.category | upper }} ]</div>
        </div>
    </section>
    {% endif %}

    <div class="main-grid">
        <div>
            <div class="section-label">Derniers articles</div>
            {% for article in latest %}
            <a class="article-card" href="{{ article.url }}">
                <div style="flex:1;">
                    <div class="card-cat">{{ article.data.badge or article.data.category }}</div>
                    <div class="card-title">{{ article.data.title }}</div>
                    <div class="card-meta">{{ article.data.author }} · {{ article.date | dateFR }}</div>
                </div>
            </a>
            {% endfor %}
        </div>

        <aside>
            <div class="section-label">À lire</div>
            {% for article in collections.articles | slice(0, 5) %}
            <div class="sidebar-item">
                <div class="sidebar-num">{{ loop.index }} · {{ article.data.category }}</div>
                <div class="sidebar-title"><a href="{{ article.url }}">{{ article.data.title }}</a></div>
            </div>
            {% endfor %}
        </aside>
    </div>

</div>
{% endblock %}
