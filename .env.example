PORT=3000
JWT_SECRET=votre_secret_jwt_tres_securise_changez_moi
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Optionnel : utiliser Firebase (Firestore) au lieu de SQLite
# USE_FIREBASE=true

# Firebase (requis si USE_FIREBASE=true)
# Option 1 : chemin vers le fichier de clé de compte de service JSON
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/serviceAccountKey.json

# Option 2 : contenu JSON de la clé en une seule ligne (pour Cloud Run / hosting)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Config client Firebase (Analytics) — exposée via GET /api/firebase-config (pas de clé en dur dans le front)
# Si définies, le front initialise Firebase avec ces valeurs.
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=test-efd07.firebaseapp.com
# FIREBASE_PROJECT_ID=test-efd07
# FIREBASE_STORAGE_BUCKET=test-efd07.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=959055652554
# FIREBASE_APP_ID=1:959055652554:web:b372381018c4a8496a7633
# FIREBASE_MEASUREMENT_ID=G-NT772NZB7E
